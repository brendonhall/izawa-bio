---
// src/components/layout/BaseLayout.astro
import '../../styles/global.css';
import NavBar from './NavBar.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Matthew R.M. Izawa — Planetary Scientist | Associate Professor, Okayama University"
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Matthew R.M. Izawa</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body class="bg-[var(--color-background)] text-[var(--color-text)] font-sans antialiased min-h-screen flex flex-col">
    <NavBar />
    <main class="max-w-[900px] w-full mx-auto px-4 sm:px-6 py-10 flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
